# Copy this to agent/.env and fill in your values.
# This file is gitignored and never mounted into the Docker container.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
DIGEST_TO=you@gmail.com

# GitHub push review (Phase 7)
GH_TOKEN=ghp_your_token_here
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=you@gmail.com
